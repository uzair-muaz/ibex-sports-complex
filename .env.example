# =============================================================================
# IBEX Sports Complex — Environment variables
# Copy this file to .env.local and fill in your values. Do not commit .env.local.
# =============================================================================

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
MONGODB_URI=mongodb://localhost:27017/ibex-sports-arena
# Production: mongodb+srv://USER:PASSWORD@cluster.mongodb.net/ibex-sports-arena

# -----------------------------------------------------------------------------
# App URL (used for emails, links, sitemap)
# -----------------------------------------------------------------------------
APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# NextAuth (admin login)
# -----------------------------------------------------------------------------
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-random-secret-key-min-32-characters

# -----------------------------------------------------------------------------
# Email — Resend (default)
# -----------------------------------------------------------------------------
EMAIL_PROVIDER=resend
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_EMAIL=IBEX Sports <noreply@yourdomain.com>

# -----------------------------------------------------------------------------
# Email — AWS SES (optional, set EMAIL_PROVIDER=ses)
# -----------------------------------------------------------------------------
# EMAIL_PROVIDER=ses
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY=your_aws_access_key
# AWS_SECRET_KEY=your_aws_secret_key
# SES_FROM_EMAIL=noreply@yourdomain.com

# -----------------------------------------------------------------------------
# SMS — AWS SNS (optional, for booking confirmation SMS)
# -----------------------------------------------------------------------------
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY=your_aws_access_key
# AWS_SECRET_KEY=your_aws_secret_key

# -----------------------------------------------------------------------------
# Seed script — Super Admin user (only for initial seed)
# -----------------------------------------------------------------------------
ADMIN_EMAIL=admin@ibex.com
ADMIN_PASSWORD=admin123
ADMIN_NAME=Super Admin

# -----------------------------------------------------------------------------
# Public (exposed to browser; optional)
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_BASE_URL=http://localhost:3000
